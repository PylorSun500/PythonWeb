     * {
            margin: 0;
            padding: 0;
        }
        .container {
            margin: 0 auto;
            width: 800px
        }
        .nav ul {
            list-style: none;
        }

        .nav ul li {
            float: left;
            width: 121px;
            text-align: center;
            background-color: #4091F5;
            color: #fff;
            font-size: 25px;
        }
        .clear::after {
            content: "";
            display: table;
            clear: both
        }

        .nav .active ,.nav ul li:hover{
            background-color: #00BDFD;
        }

        .news ul {
            list-style: none;
        }
        .news ul li {
            float: left;
            text-align: center;
            font-size: 20px;
            width: 240px;
            font-weight: bloder;
            border-bottom: 2px solid #ccc;
        }

        .news ul li.active {
            color: #5577ee;
            border-bottom: 2px solid #5577ee;
        }


        .news li:hover{
            color: #5577ee;
            border-bottom: 2px solid #5577ee;
        }


        .newslist li.list {
            display: block;
            text-align: left;
            border-bottom: none;
            padding: 5px;
            width: 720px;
            padding-left: 15px;
            background:url("/static/img/point.jpg")  no-repeat 0px 10px ;

        }

        .newslist span {
            float: right;
        }

        .footer {
            background-color: #474e60;
           font-size: 14px;
            width: 720px;
            color: #aaa;
            text-align: center;
        }
        .footer ul {
            list-style: none;
            width: 400px;
            margin: 0 auto;


        }

        .footer ul li {
            display: block;
            float: left;
            margin: 20px;
            width: 80px;
        }